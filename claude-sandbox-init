#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: claude-sandbox-init [TARGET_DIR]

Initialize a directory for running Claude Code in a sandbox container.
Uses the current directory if TARGET_DIR is not specified.

The generated targets provide two launch modes:
  make sandbox-run          Start in code mode (firewall enabled)
  make sandbox-run-research Start in research mode (open network, git repos blocked)

Creates:
  claude/                     Per-instance config (bootstrapped on first run)
  commandhistory/             Persistent bash history
  claude-sandbox-compose.yml  Container run config
  claude-sandbox.mk           Make targets: sandbox-run, sandbox-connect, ...
  Makefile                    Created if missing; otherwise gets an
                              `include claude-sandbox.mk` block appended

Resolution of the claude-sandbox repo location, in order:
  1. $CLAUDE_SANDBOX_HOME if set
  2. The directory containing this script (resolved through symlinks)
  3. $HOME/claude-sandbox

Environment:
  CLAUDE_SANDBOX_HOME  Override auto-detection of the claude-sandbox repo
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

is_sandbox_home() {
  local dir="$1"
  [ -d "$dir" ] \
    && [ -f "$dir/Dockerfile" ] \
    && [ -f "$dir/init-firewall.sh" ] \
    && [ -f "$dir/claude-sandbox-compose.yml" ] \
    && [ -d "$dir/claude-template" ]
}

resolve_sandbox_home() {
  if [ -n "${CLAUDE_SANDBOX_HOME:-}" ]; then
    if is_sandbox_home "$CLAUDE_SANDBOX_HOME"; then
      echo "$CLAUDE_SANDBOX_HOME"
    fi
    return
  fi
  local script_dir
  script_dir="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")"
  if is_sandbox_home "$script_dir"; then
    echo "$script_dir"
    return
  fi
  if is_sandbox_home "$HOME/claude-sandbox"; then
    echo "$HOME/claude-sandbox"
    return
  fi
}

PROBLEMS=()

for cmd in docker mkdir cat readlink grep; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    PROBLEMS+=("required command not found: $cmd")
  fi
done

RESOLVED_HOME="$(resolve_sandbox_home || true)"
if [ -n "$RESOLVED_HOME" ]; then
  CLAUDE_SANDBOX_HOME="$RESOLVED_HOME"
elif [ -n "${CLAUDE_SANDBOX_HOME:-}" ]; then
  PROBLEMS+=("CLAUDE_SANDBOX_HOME is set to '$CLAUDE_SANDBOX_HOME' but that is not a valid claude-sandbox repo (missing Dockerfile, init-firewall.sh, claude-sandbox-compose.yml, or claude-template/)")
else
  PROBLEMS+=("could not locate the claude-sandbox repo. Tried: directory of this script, and \$HOME/claude-sandbox.
    Fix by one of:
      - symlink the script into your PATH:  ln -sf /path/to/claude-sandbox/claude-sandbox-init ~/bin/claude-sandbox-init
      - clone the repo to \$HOME/claude-sandbox
      - export CLAUDE_SANDBOX_HOME=/path/to/claude-sandbox")
fi

if ! docker image inspect claude-sandbox >/dev/null 2>&1; then
  if [ -n "$RESOLVED_HOME" ]; then
    PROBLEMS+=("claude-sandbox image not built. Build it with: cd $RESOLVED_HOME && make build")
  else
    PROBLEMS+=("claude-sandbox image not built. Build it from the repo with: make build")
  fi
fi

if [ ${#PROBLEMS[@]} -gt 0 ]; then
  echo "Error: cannot proceed:"
  for p in "${PROBLEMS[@]}"; do
    echo "  - $p"
  done
  exit 1
fi

TARGET_DIR="${1:-.}"
TARGET_DIR="$(cd "$TARGET_DIR" && pwd)"

echo "Initializing claude-sandbox in: $TARGET_DIR"

mkdir -p "$TARGET_DIR/claude" "$TARGET_DIR/commandhistory"

cat "$CLAUDE_SANDBOX_HOME/claude-sandbox-compose.yml" > "$TARGET_DIR/claude-sandbox-compose.yml"

{
  echo "SANDBOX_REPO := $CLAUDE_SANDBOX_HOME"
  cat <<'MAKEOF'
SANDBOX_COMPOSE := docker compose -f claude-sandbox-compose.yml

.PHONY: sandbox-run sandbox-run-research sandbox-connect sandbox-stop sandbox-destroy sandbox-status sandbox-help _sandbox-check-image

_sandbox-check-image:
	@docker image inspect claude-sandbox >/dev/null 2>&1 || { \
		echo "Error: claude-sandbox image not found."; \
		echo "Build it with: cd $(SANDBOX_REPO) && make build"; \
		exit 1; \
	}

## Start the sandbox in code mode (firewall enabled)
sandbox-run: _sandbox-check-image
	SANDBOX_MODE=code $(SANDBOX_COMPOSE) up -d

## Start the sandbox in research mode (open network, no git repos allowed)
sandbox-run-research: _sandbox-check-image
	SANDBOX_MODE=research $(SANDBOX_COMPOSE) up -d

## Attach a bash shell to the running sandbox
sandbox-connect:
	docker exec -it $$($(SANDBOX_COMPOSE) ps -q claude-sandbox) bash

## Stop the sandbox (keeps state)
sandbox-stop:
	$(SANDBOX_COMPOSE) stop

## Remove the sandbox container
sandbox-destroy:
	$(SANDBOX_COMPOSE) down

## Show container status
sandbox-status:
	$(SANDBOX_COMPOSE) ps

## Show claude-sandbox targets
sandbox-help:
	@echo "claude-sandbox targets:"
	@echo "  sandbox-run          - Start in code mode (firewall enabled)"
	@echo "  sandbox-run-research - Start in research mode (open network)"
	@echo "  sandbox-connect      - Attach a bash shell"
	@echo "  sandbox-stop         - Stop the sandbox (keeps state)"
	@echo "  sandbox-destroy      - Remove the sandbox container"
	@echo "  sandbox-status       - Show container status"
MAKEOF
} > "$TARGET_DIR/claude-sandbox.mk"

MAKEFILE="$TARGET_DIR/Makefile"
INCLUDE_LINE='include claude-sandbox.mk'
if [ ! -e "$MAKEFILE" ]; then
  cat > "$MAKEFILE" <<'EOF'
### BEGIN claude-sandbox ###
include claude-sandbox.mk
### END claude-sandbox ###
EOF
  echo "Created Makefile with claude-sandbox include block."
elif grep -qF "$INCLUDE_LINE" "$MAKEFILE"; then
  : # already wired up
else
  cat >> "$MAKEFILE" <<'EOF'

### BEGIN claude-sandbox ###
include claude-sandbox.mk
### END claude-sandbox ###
EOF
  echo "Appended claude-sandbox include block to existing Makefile."
fi

echo ""
echo "Done. Next steps:"
echo "  cd $TARGET_DIR"
echo "  make sandbox-run"
echo "  make sandbox-connect"
echo "  # On first run: claude login"
